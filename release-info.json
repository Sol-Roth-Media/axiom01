{
  "version": "2.0.0",
  "name": "axiom01",
  "description": "Semantic-first UI framework with professional design system, animations, utilities, and components",
  "releaseDate": "2025-01-20",
  "releaseDateFormatted": "January 20, 2025",
  "license": "MIT",
  "author": "Sol Roth Media",
  "repository": "https://github.com/Sol-Roth-Media/axiom01",
  "npm": "https://www.npmjs.com/package/axiom01",
  "demo": "https://axiom01.com",
  "bundle": {
    "css": {
      "size": "~40 KB",
      "sizeGzipped": "~40 KB",
      "note": "Full framework with all components, animations, utilities, dark mode, and design tokens"
    },
    "js": {
      "size": "~8 KB",
      "sizeGzipped": "~8 KB",
      "note": "Optional component loader"
    },
    "total": {
      "size": "~48 KB",
      "sizeGzipped": "~48 KB",
      "note": "Total production build"
    }
  },
  "features": {
    "components": 6,
    "designTokens": 50,
    "animations": 20,
    "utilities": 100,
    "sizes": 4,
    "buttonTypes": 7,
    "cardVariants": 5,
    "badgeColors": 6,
    "alertTypes": 4,
    "breakpoints": 6
  },
  "accessibility": {
    "wcagLevel": "WCAG 2.1 Level AA",
    "keyboardNavigation": true,
    "darkMode": true,
    "screenReaderSupport": true,
    "colorContrast": "4.5:1 minimum"
  },
  "dependencies": 0,
  "jsRequired": false,
  "backwardCompatible": true,
  "buildRequired": false,
  "browsers": {
    "chrome": "90+",
    "firefox": "88+",
    "safari": "14+",
    "edge": "90+",
    "iosSafari": "14+",
    "android": "90+"
  },
  "highlights": [
    "Semantic-first philosophy",
    "One class per component",
    "50+ design tokens",
    "20+ GPU-accelerated animations",
    "WCAG 2.1 AA accessible",
    "Dark mode built-in",
    "Zero dependencies",
    "~40KB CSS gzipped",
    "No build tools required",
    "100% backward compatible"
  ],
  "cdnLinks": {
    "css": "https://unpkg.com/axiom01@2.0.0/css/axiom.min.css",
    "js": "https://unpkg.com/axiom01@2.0.0/js/axiom.min.js",
    "unpackedSize": "283.2 kB"
  },
  "npmCommand": "npm install axiom01",
  "yarnCommand": "yarn add axiom01",
  "pnpmCommand": "pnpm add axiom01",
  "importCss": "@import 'axiom01/css/axiom.min.css';",
  "importJs": "import 'axiom01/css/axiom.min.css';",
  "related": {
    "dbaseStarter": "https://github.com/Sol-Roth-Media/dbase",
    "gemmini_axiom_expert": "https://aistudio.google.com",
    "gemmini_dbase_starter": "https://aistudio.google.com"
  }
}
