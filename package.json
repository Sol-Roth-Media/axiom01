{
  "name": "axiom01",
  "version": "1.0.2",
  "description": "Semantic-first UI framework and documentation site",
  "license": "MIT",
  "main": "index.js",
  "files": [
    "css/axiom.min.css",
    "js/axiom.min.js",
    "readme.md",
    "LICENSE"
  ],
  "scripts": {
    "sync:drupal-assets": "python3 scripts/sync_drupal_starter_assets.py",
    "audit:drupal-assets": "python3 scripts/sync_drupal_starter_assets.py --check",
    "build": "npm run sync:drupal-assets && python3 scripts/build_release_dist.py",
    "audit:pre-release": "python3 scripts/pre_release_audit.py",
    "audit:runtime-loader": "python3 scripts/runtime_loader_syntax_gate.py",
    "audit:critical-interactions": "python3 scripts/critical_interaction_smoke.py",
    "audit:a11y-smoke": "python3 scripts/accessibility_smoke.py",
    "test": "npm run audit:drupal-assets && npm run audit:pre-release && npm run audit:runtime-loader && npm run audit:critical-interactions && npm run audit:a11y-smoke"
  }
}
