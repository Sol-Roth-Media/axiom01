{# Branding block with configurable logo/site identity output. #}
{{ title_prefix }}
<div class="site-branding" data-component="site-branding">
  {% if site_logo %}
    <a href="{{ path('<front>') }}" rel="home">
      <img src="{{ site_logo }}" alt="{{ 'Home'|t }}" fetchpriority="high" />
    </a>
  {% endif %}

  {% if site_name %}
    <a href="{{ path('<front>') }}" rel="home">{{ site_name }}</a>
  {% endif %}

  {% if site_slogan %}
    <p>{{ site_slogan }}</p>
  {% endif %}

  {% if not site_logo and not site_name %}
    <a href="{{ path('<front>') }}" rel="home">
      [Ax01]
    </a>
  {% endif %}
</div>
{{ title_suffix }}
