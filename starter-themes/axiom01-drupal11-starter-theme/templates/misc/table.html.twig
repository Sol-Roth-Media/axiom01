{# Semantic table output with optional Axiom advanced-table behavior hook. #}
{% set column_count = header ? header|length : 1 %}
<section data-component="advanced-table">
  <table{{ attributes }}>
    {% if caption %}
      <caption>{{ caption }}</caption>
    {% endif %}

    {% for colgroup in colgroups %}
      <colgroup{{ colgroup.attributes }}>
        {% for col in colgroup.cols %}
          <col{{ col.attributes }} />
        {% endfor %}
      </colgroup>
    {% endfor %}

    {% if header %}
      <thead>
        <tr>
          {% for cell in header %}
            <{{ cell.tag }}{{ cell.attributes }}>{{ cell.content }}</{{ cell.tag }}>
          {% endfor %}
        </tr>
      </thead>
    {% endif %}

    {% if rows %}
      <tbody>
        {% for row in rows %}
          <tr{{ row.attributes }}>
            {% for cell in row.cells %}
              <{{ cell.tag }}{{ cell.attributes }}>{{ cell.content }}</{{ cell.tag }}>
            {% endfor %}
          </tr>
        {% endfor %}
      </tbody>
    {% elseif empty %}
      <tbody>
        <tr>
          <td colspan="{{ column_count }}">{{ empty }}</td>
        </tr>
      </tbody>
    {% endif %}
  </table>
</section>
