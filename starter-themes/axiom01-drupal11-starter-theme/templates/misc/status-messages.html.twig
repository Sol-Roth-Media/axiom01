{# Accessible status messages mapped to alert semantics. #}
{% for type, messages in message_list %}
  <section role="status" aria-live="polite" class="alert {{ type|clean_class }}" data-component="alert">
    <ul>
      {% for message in messages %}
        <li>{{ message }}</li>
      {% endfor %}
    </ul>
  </section>
{% endfor %}
