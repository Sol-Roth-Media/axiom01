{# Local tasks wrapper mapped to Axiom dropdown behavior on narrow layouts. #}
{% if primary or secondary %}
  <nav{{ attributes.setAttribute('data-component', 'dropdown') }} aria-label="{{ 'Local tasks'|t }}">
    {% if primary %}
      <h2 class="visually-hidden">{{ 'Primary tabs'|t }}</h2>
      {{ primary }}
    {% endif %}
    {% if secondary %}
      <h2 class="visually-hidden">{{ 'Secondary tabs'|t }}</h2>
      {{ secondary }}
    {% endif %}
  </nav>
{% endif %}
