{# Branding block with configurable logo/site identity output. #}
{{ title_prefix }}
<div class="site-branding">
  {% if site_logo %}
    <a class="brand brand-logo" href="{{ path('<front>') }}" rel="home">
      <img src="{{ site_logo }}" alt="{{ 'Home'|t }}" fetchpriority="high" />
    </a>
  {% endif %}

  {% if site_name %}
    <a class="brand brand-name" href="{{ path('<front>') }}" rel="home">{{ site_name }}</a>
  {% endif %}

  {% if site_slogan %}
    <div class="brand brand-slogan">{{ site_slogan }}</div>
  {% endif %}

  {% if not site_logo and not site_name %}
    <a class="brand" href="{{ path('<front>') }}" rel="home">
      [Ax<span class="primary">01</span>]
    </a>
  {% endif %}
</div>
{{ title_suffix }}
