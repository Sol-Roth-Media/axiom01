{# Generic Drupal block wrapper with Axiom-first semantic shells. #}
{{ title_prefix }}
<{{ axiom_block_tag|default('section') }}{{ attributes }}>
  {% if label %}
    <h2{{ title_attributes }}>{{ label }}</h2>
  {% endif %}
  {{ content }}
</{{ axiom_block_tag|default('section') }}>
{{ title_suffix }}
