{#
/**
 * @file
 * Axiom01 views exposed form template.
 *
 * Outputs the exposed filter form with minimal markup so axiom.css
 * form styles apply naturally. The .axiom-form preprocess hook on the
 * parent form element provides spacing/input styles.
 *
 * Variables:
 * - form: the exposed filter form render array
 * - q: hidden query field for clean URLs (optional)
 */
#}
{% if q %}
  {{ q }}
{% endif %}
{{ form }}
