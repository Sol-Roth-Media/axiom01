{#
/**
 * @file
 * Default page template for Axiom01 Drupal 11 starter theme.
 */
#}
<header class="main" data-component="mobile-navbar">
  <div class="ax-layout">
    {{ page.header }}
    <nav aria-label="Primary">
      {{ page.primary_menu }}
    </nav>
  </div>
</header>

{% if page.utility %}
  <div class="ax-layout ax-utility">
    {{ page.utility }}
  </div>
{% endif %}

<main class="ax-layout" role="main">
  {{ page.content }}
</main>

<footer class="main">
  <div class="ax-layout">
    {% if page.footer_menu %}
      <nav aria-label="Footer">
        {{ page.footer_menu }}
      </nav>
    {% endif %}
    {{ page.footer }}
  </div>
</footer>
