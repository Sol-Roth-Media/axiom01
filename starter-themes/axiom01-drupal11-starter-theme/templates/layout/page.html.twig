{#
/**
 * @file
 * Default page template for Axiom01 Drupal 11 starter theme.
 */
#}
{% if page.top_bar %}
  <section aria-label="Top bar">
    {{ page.top_bar }}
  </section>
{% endif %}

<header data-component="mobile-navbar">
  {{ page.header }}
  <nav aria-label="Primary">
    {{ page.primary_menu|default(ax_primary_menu_fallback) }}
  </nav>
  {% if page.secondary_menu or ax_secondary_menu_fallback %}
    <nav aria-label="Secondary">
      {{ page.secondary_menu|default(ax_secondary_menu_fallback) }}
    </nav>
  {% endif %}
</header>

{% if page.utility %}
  <section aria-label="Utility">
    {{ page.utility }}
  </section>
{% endif %}

{% if page.highlighted %}
  <section aria-label="Highlighted">
    {{ page.highlighted }}
  </section>
{% endif %}

{% if page.breadcrumb %}
  <nav aria-label="Breadcrumb">
    {{ page.breadcrumb }}
  </nav>
{% endif %}

{% if page.help %}
  <section aria-label="Help">
    {{ page.help }}
  </section>
{% endif %}

{% if page.hero %}
  <section aria-label="Hero">
    {{ page.hero }}
  </section>
{% endif %}

{% if page.content_above %}
  <section aria-label="Content above">
    {{ page.content_above }}
  </section>
{% endif %}

<main role="main">
  {% if page.sidebar_first %}
    <aside aria-label="Sidebar">
      {{ page.sidebar_first }}
    </aside>
  {% endif %}

  {{ page.content }}

  {% if page.sidebar_second %}
    <aside aria-label="Secondary sidebar">
      {{ page.sidebar_second }}
    </aside>
  {% endif %}
</main>

{% if page.content_below %}
  <section aria-label="Content below">
    {{ page.content_below }}
  </section>
{% endif %}

{% if page.prefooter %}
  <section aria-label="Prefooter">
    {{ page.prefooter }}
  </section>
{% endif %}

<footer>
  {% if page.footer_first or page.footer_second or page.footer_third %}
    <section aria-label="Footer columns">
      {{ page.footer_first }}
      {{ page.footer_second }}
      {{ page.footer_third }}
    </section>
  {% endif %}
  {% if page.footer_menu %}
    <nav aria-label="Footer">
      {{ page.footer_menu }}
    </nav>
  {% endif %}
  {{ page.footer }}
</footer>

{% if page.bottom %}
  <section aria-label="Bottom">
    {{ page.bottom }}
  </section>
{% endif %}
