<?php

/**
 * @file
 * Theme hooks and preprocessors for axiom01_drupal11.
 */

use Drupal\Core\Template\Attribute;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Menu\MenuTreeParameters;

/**
 * Normalize classes to a minimal allowlist while preserving non-class attrs.
 */
function _axiom01_drupal11_normalize_attributes($source, array $allowed_classes = []): Attribute {
  if ($source instanceof Attribute) {
    $values = $source->toArray();
  }
  elseif (is_array($source)) {
    $values = $source;
  }
  else {
    $values = [];
  }

  $normalized = new Attribute();

  foreach ($values as $name => $value) {
    if ($name === 'class') {
      continue;
    }
    $normalized->setAttribute($name, $value);
  }

  $classes = [];
  if (!empty($values['class'])) {
    $existing_classes = is_array($values['class']) ? $values['class'] : [$values['class']];
    foreach ($existing_classes as $class_name) {
      if (in_array($class_name, $allowed_classes, TRUE)) {
        $classes[] = $class_name;
      }
    }
  }
  foreach ($allowed_classes as $class_name) {
    $classes[] = $class_name;
  }

  if ($classes) {
    $normalized->addClass(array_values(array_unique($classes)));
  }

  return $normalized;
}

/**
 * Build a renderable menu tree for fallback navigation output.
 */
function _axiom01_drupal11_build_menu_tree(string $menu_name): array {
  $menu_tree = \Drupal::menuTree();
  $parameters = (new MenuTreeParameters())
    ->setMinDepth(1)
    ->onlyEnabledLinks();
  $tree = $menu_tree->load($menu_name, $parameters);
  $manipulators = [
    ['callable' => 'menu.default_tree_manipulators:checkAccess'],
    ['callable' => 'menu.default_tree_manipulators:generateIndexAndSort'],
  ];
  $tree = $menu_tree->transform($tree, $manipulators);
  return $menu_tree->build($tree);
}

/**
 * Resolve the selected Axiom01 asset strategy to a theme library.
 */
function _axiom01_drupal11_resolve_assets_library(string $strategy): string {
  $theme_path = \Drupal::service('extension.list.theme')->getPath('axiom01_drupal11');
  $package_assets_exist = file_exists($theme_path . '/vendor/axiom01/dist/css/axiom.min.css')
    && file_exists($theme_path . '/vendor/axiom01/dist/js/axiom.min.js');

  if ($strategy === 'package' && $package_assets_exist) {
    return 'axiom01_drupal11/axiom01_assets_package';
  }

  if ($strategy === 'package') {
    return 'axiom01_drupal11/axiom01_assets_local';
  }

  if ($strategy === 'local') {
    return 'axiom01_drupal11/axiom01_assets_local';
  }

  if ($package_assets_exist) {
    return 'axiom01_drupal11/axiom01_assets_package';
  }

  return 'axiom01_drupal11/axiom01_assets_local';
}

/**
 * Implements hook_preprocess_html().
 */
function axiom01_drupal11_preprocess_html(array &$variables): void {
  $config = \Drupal::config('axiom01_drupal11.settings');
  $attributes = $variables['attributes'] ?? [];
  if (!$attributes instanceof Attribute) {
    $attributes = new Attribute(is_array($attributes) ? $attributes : []);
  }
  $color_mode = (string) ($config->get('color_mode') ?: 'light');
  $initial_mode = $color_mode === 'dark' ? 'dark' : 'light';
  $attributes->setAttribute('data-theme', $initial_mode);
  $attributes->setAttribute('data-theme-mode', $color_mode);
  $attributes->setAttribute('data-axiom-palette', (string) ($config->get('color_palette') ?: 'default'));
  $attributes->setAttribute('data-font-body', (string) ($config->get('body_font') ?: 'inter'));
  $attributes->setAttribute('data-font-heading', (string) ($config->get('heading_font') ?: 'inter'));
  $attributes->setAttribute('data-spacing-scale', (string) ($config->get('spacing_scale') ?: 'comfortable'));
  $attributes->setAttribute('data-layout-width', (string) ($config->get('layout_width') ?: 'standard'));
  $attributes->setAttribute('data-icon-set', (string) ($config->get('icon_set') ?: 'none'));
  $attributes->setAttribute('data-character-set', (string) ($config->get('character_set') ?: 'utf-8'));
  $attributes->addClass('axiom01-theme-ready');
  $variables['attributes'] = $attributes;

  $body_attributes = $variables['body_attributes'] ?? [];
  if (!$body_attributes instanceof Attribute) {
    $body_attributes = new Attribute(is_array($body_attributes) ? $body_attributes : []);
  }
  $variables['body_attributes'] = $body_attributes;
  $variables['body_attributes']->addClass('axiom-body');

  $strategy = (string) $config->get('asset_strategy');
  $variables['#attached']['library'][] = _axiom01_drupal11_resolve_assets_library($strategy);
}

/**
 * Implements hook_preprocess_page().
 */
function axiom01_drupal11_preprocess_page(array &$variables): void {
  $variables['ax_theme_name'] = 'Axiom01 Drupal 11';
  $variables['ax_primary_menu_fallback'] = !empty($variables['page']['primary_menu']) ? [] : _axiom01_drupal11_build_menu_tree('main');
  $variables['ax_secondary_menu_fallback'] = !empty($variables['page']['secondary_menu']) ? [] : _axiom01_drupal11_build_menu_tree('account');
}

/**
 * Implements hook_preprocess_form().
 */
function axiom01_drupal11_preprocess_form(array &$variables): void {
  $attributes = $variables['attributes'] ?? [];
  if (!$attributes instanceof Attribute) {
    $attributes = new Attribute(is_array($attributes) ? $attributes : []);
  }
  $attributes->addClass('axiom-form');
  $variables['attributes'] = $attributes;
}

/**
 * Implements hook_preprocess_details().
 */
function axiom01_drupal11_preprocess_details(array &$variables): void {
  $variables['attributes'] = _axiom01_drupal11_normalize_attributes($variables['attributes'] ?? [], []);
}

/**
 * Implements hook_preprocess_block().
 */
function axiom01_drupal11_preprocess_block(array &$variables): void {
  $variables['attributes'] = _axiom01_drupal11_normalize_attributes($variables['attributes'] ?? [], []);
  $plugin_id = (string) ($variables['elements']['#plugin_id'] ?? '');
  $region = (string) ($variables['elements']['#configuration']['region'] ?? '');
  $variables['axiom_block_tag'] = 'section';
  $variables['axiom_block_variant'] = '';

  if (str_contains($region, 'sidebar') || str_contains($region, 'aside')) {
    $variables['axiom_block_tag'] = 'aside';
  }
  elseif (str_contains($region, 'content') || str_starts_with($plugin_id, 'views_block:')) {
    $variables['axiom_block_tag'] = 'article';
  }

  if ($plugin_id === 'search_form_block' || $plugin_id === 'axiom01_drupal_default_search_block') {
    $variables['attributes'] = _axiom01_drupal11_normalize_attributes($variables['attributes'], ['search']);
  }
}

/**
 * Implements hook_preprocess_menu_local_tasks().
 */
function axiom01_drupal11_preprocess_menu_local_tasks(array &$variables): void {
  $variables['attributes'] = _axiom01_drupal11_normalize_attributes($variables['attributes'] ?? [], ['tabs']);
}

/**
 * Implements hook_preprocess_pager().
 */
function axiom01_drupal11_preprocess_pager(array &$variables): void {
  $variables['attributes'] = _axiom01_drupal11_normalize_attributes($variables['attributes'] ?? [], ['pager']);
  if (empty($variables['heading_id'])) {
    $variables['heading_id'] = 'pagination-heading';
  }
}

