}

/**
 * Implements hook_form_system_theme_settings_alter().
 */
function axiom01_drupal11_form_system_theme_settings_alter(array &$form, FormStateInterface $form_state): void {
  $config = \Drupal::config('axiom01_drupal11.settings');
  $form['axiom01_assets'] = [
    '#type' => 'details',
    '#title' => t('Axiom01 assets'),
    '#open' => TRUE,
  ];

  $form['axiom01_assets']['asset_strategy'] = [
    '#type' => 'select',
    '#title' => t('Asset strategy'),
    '#description' => t('Auto prefers package-managed assets when present and otherwise falls back to local dist assets. Use auto for most sites, local when packaging a self-contained theme release, and package when your deployment pipeline always installs vendor assets from Axiom01 updates.'),
    '#default_value' => $config->get('asset_strategy') ?: 'auto',
    '#options' => [
      'auto' => t('Auto (prefer package-managed, then local fallback)'),
      'local' => t('Local dist assets'),
      'package' => t('Package-managed copy'),
    ],
  ];

  $form['axiom01_appearance'] = [
    '#type' => 'details',
    '#title' => t('Axiom01 appearance'),
    '#open' => TRUE,
  ];

  $form['axiom01_appearance']['color_mode'] = [
    '#type' => 'select',
    '#title' => t('Color mode'),
    '#description' => t('Choose default color mode for frontend rendering. System follows browser preference.'),
    '#default_value' => $config->get('color_mode') ?: 'light',
    '#options' => [
      'light' => t('Light'),
      'dark' => t('Dark'),
      'system' => t('System preference'),
    ],
  ];

  $form['axiom01_appearance']['color_palette'] = [
    '#type' => 'select',
    '#title' => t('Color palette'),
    '#default_value' => $config->get('color_palette') ?: 'default',
    '#options' => [
      'default' => t('Default blue'),
      'indigo' => t('Indigo'),
      'emerald' => t('Emerald'),
      'sunset' => t('Sunset'),
    ],
  ];

  $form['axiom01_appearance']['body_font'] = [
    '#type' => 'select',
    '#title' => t('Body font'),
    '#default_value' => $config->get('body_font') ?: 'inter',
    '#options' => [
      'inter' => t('Inter / sans-serif'),
      'system' => t('System sans-serif'),
      'serif' => t('Serif'),
      'mono' => t('Monospace'),
    ],
  ];

  $form['axiom01_appearance']['heading_font'] = [
    '#type' => 'select',
    '#title' => t('Heading font'),
    '#default_value' => $config->get('heading_font') ?: 'inter',
    '#options' => [
      'inter' => t('Inter / sans-serif'),
      'system' => t('System sans-serif'),
      'serif' => t('Serif'),
      'mono' => t('Monospace'),
    ],
  ];

  $form['axiom01_appearance']['spacing_scale'] = [
    '#type' => 'select',
    '#title' => t('Spacing scale'),
    '#default_value' => $config->get('spacing_scale') ?: 'comfortable',
    '#options' => [
      'compact' => t('Compact'),
      'comfortable' => t('Comfortable'),
      'relaxed' => t('Relaxed'),
    ],
  ];

  $form['axiom01_appearance']['layout_width'] = [
    '#type' => 'select',
    '#title' => t('Layout width'),
    '#default_value' => $config->get('layout_width') ?: 'standard',
    '#options' => [
      'narrow' => t('Narrow (960px)'),
      'standard' => t('Standard (1200px)'),
      'wide' => t('Wide (1440px)'),
    ],
  ];

  $form['axiom01_appearance']['icon_set'] = [
    '#type' => 'select',
    '#title' => t('Icon set'),
    '#description' => t('Declare expected icon strategy for theme/component rendering conventions.'),
    '#default_value' => $config->get('icon_set') ?: 'none',
    '#options' => [
      'none' => t('None / text-first'),
      'emoji' => t('Emoji'),
      'fontawesome' => t('Font Awesome'),
      'material' => t('Material Symbols'),
    ],
  ];

  $form['axiom01_appearance']['character_set'] = [
    '#type' => 'select',
    '#title' => t('Character set'),
    '#description' => t('Declare expected content encoding for multilingual/content pipelines.'),
    '#default_value' => $config->get('character_set') ?: 'utf-8',
    '#options' => [
      'utf-8' => t('UTF-8 (recommended)'),
      'iso-8859-1' => t('ISO-8859-1'),
      'windows-1252' => t('Windows-1252'),
    ],
  ];
}
