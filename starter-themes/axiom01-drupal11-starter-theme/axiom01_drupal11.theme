/**
 * Implements hook_preprocess_ajax_progress().
 */
function axiom01_drupal11_preprocess_ajax_progress(array &$variables): void {
  $allowed_classes = ['ajax-progress'];
  if (!empty($variables['type']) && $variables['type'] === 'throbber') {
    $allowed_classes[] = 'ajax-progress-throbber';
  }
  $variables['attributes'] = _axiom01_drupal11_normalize_attributes($variables['attributes'] ?? [], $allowed_classes);
}

/**
 * Implements hook_preprocess_progress_bar().
