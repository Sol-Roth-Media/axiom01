{
  "Axiom Component Registration": {
    "prefix": "ax-register",
    "body": [
      "AxiomComponents.register('${1:componentName}', {",
      "\tinit() {",
      "\t\tthis.element = document.querySelector('.${2:component-class}');",
      "\t\tif (!this.element) return;",
      "\t\t$3",
      "\t},",
      "\tdestroy() {",
      "\t\t$4",
      "\t},",
      "\tupdate() {",
      "\t\t$5",
      "\t}",
      "});"
    ],
    "description": "Register a new component with the Axiom01 system"
  },
  "Axiom Event Listener": {
    "prefix": "ax-listen",
    "body": [
      "this.element.addEventListener('${1:event}', (e) => {",
      "\te.preventDefault();",
      "\t$2",
      "});"
    ],
    "description": "Add event listener with Axiom01 patterns"
  },
  "Axiom ARIA Helper": {
    "prefix": "ax-aria",
    "body": [
      "// Set ARIA attributes",
      "this.element.setAttribute('aria-${1:expanded}', '${2:false}');",
      "this.element.setAttribute('role', '${3:button}');",
      "$4"
    ],
    "description": "Add ARIA attributes for accessibility"
  },
  "Axiom Focus Management": {
    "prefix": "ax-focus-trap",
    "body": [
      "// Focus trap implementation",
      "const focusableElements = this.element.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex=\"-1\"])');",
      "const firstElement = focusableElements[0];",
      "const lastElement = focusableElements[focusableElements.length - 1];",
      "",
      "this.element.addEventListener('keydown', (e) => {",
      "\tif (e.key === 'Tab') {",
      "\t\tif (e.shiftKey) {",
      "\t\t\tif (document.activeElement === firstElement) {",
      "\t\t\t\te.preventDefault();",
      "\t\t\t\tlastElement.focus();",
      "\t\t\t}",
      "\t\t} else {",
      "\t\t\tif (document.activeElement === lastElement) {",
      "\t\t\t\te.preventDefault();",
      "\t\t\t\tfirstElement.focus();",
      "\t\t\t}",
      "\t\t}",
      "\t}",
      "});"
    ],
    "description": "Implement focus trapping for modals and drawers"
  },
  "Axiom Theme Toggle": {
    "prefix": "ax-theme",
    "body": [
      "const toggleTheme = () => {",
      "\tconst currentTheme = document.documentElement.dataset.theme || 'light';",
      "\tconst newTheme = currentTheme === 'light' ? 'dark' : 'light';",
      "\t",
      "\tdocument.documentElement.dataset.theme = newTheme;",
      "\tlocalStorage.setItem('axiom-theme', newTheme);",
      "\t",
      "\t// Announce to screen readers",
      "\tconst announcement = document.createElement('div');",
      "\tannouncement.setAttribute('aria-live', 'polite');",
      "\tannouncement.textContent = `Theme switched to ${newTheme} mode`;",
      "\tdocument.body.appendChild(announcement);",
      "\tsetTimeout(() => announcement.remove(), 1000);",
      "};"
    ],
    "description": "Create accessible theme toggle functionality"
  },
  "Axiom Keyboard Navigation": {
    "prefix": "ax-keyboard",
    "body": [
      "this.element.addEventListener('keydown', (e) => {",
      "\tswitch (e.key) {",
      "\t\tcase 'Escape':",
      "\t\t\te.preventDefault();",
      "\t\t\t$1",
      "\t\t\tbreak;",
      "\t\tcase 'Enter':",
      "\t\tcase ' ':",
      "\t\t\te.preventDefault();",
      "\t\t\t$2",
      "\t\t\tbreak;",
      "\t\tcase 'ArrowUp':",
      "\t\t\te.preventDefault();",
      "\t\t\t$3",
      "\t\t\tbreak;",
      "\t\tcase 'ArrowDown':",
      "\t\t\te.preventDefault();",
      "\t\t\t$4",
      "\t\t\tbreak;",
      "\t}",
      "});"
    ],
    "description": "Add keyboard navigation patterns"
  },
  "Axiom Live Region": {
    "prefix": "ax-announce",
    "body": [
      "const announce = (message, priority = 'polite') => {",
      "\tconst liveRegion = document.createElement('div');",
      "\tliveRegion.setAttribute('aria-live', priority);",
      "\tliveRegion.setAttribute('aria-atomic', 'true');",
      "\tliveRegion.className = 'sr-only';",
      "\tliveRegion.textContent = message;",
      "\t",
      "\tdocument.body.appendChild(liveRegion);",
      "\tsetTimeout(() => liveRegion.remove(), 1000);",
      "};"
    ],
    "description": "Create ARIA live region for screen reader announcements"
  }
}

