{
  "Axiom Button": {
    "prefix": "ax-button",
    "body": [
      "<button class=\"${1|primary,secondary,tertiary,danger,success|}\"${2: type=\"${3|button,submit,reset|}\"}>",
      "\t$4",
      "</button>"
    ],
    "description": "Creates an Axiom01 button with semantic classes"
  },
  "Axiom Card": {
    "prefix": "ax-card",
    "body": [
      "<article class=\"card\">",
      "\t<header>",
      "\t\t<h3>$1</h3>",
      "\t</header>",
      "\t<section>",
      "\t\t<p>$2</p>",
      "\t</section>",
      "\t<footer>",
      "\t\t<button class=\"primary\">$3</button>",
      "\t</footer>",
      "</article>"
    ],
    "description": "Creates an Axiom01 card component with semantic structure"
  },
  "Axiom Modal": {
    "prefix": "ax-modal",
    "body": [
      "<dialog class=\"modal\" id=\"${1:modal-id}\" aria-labelledby=\"${1:modal-id}-title\" aria-describedby=\"${1:modal-id}-desc\">",
      "\t<article>",
      "\t\t<header>",
      "\t\t\t<h2 id=\"${1:modal-id}-title\">$2</h2>",
      "\t\t\t<button class=\"close\" aria-label=\"Close modal\">&times;</button>",
      "\t\t</header>",
      "\t\t<section id=\"${1:modal-id}-desc\">",
      "\t\t\t<p>$3</p>",
      "\t\t</section>",
      "\t\t<footer>",
      "\t\t\t<button class=\"primary\">$4</button>",
      "\t\t\t<button class=\"secondary\">Cancel</button>",
      "\t\t</footer>",
      "\t</article>",
      "</dialog>"
    ],
    "description": "Creates an accessible Axiom01 modal dialog"
  },
  "Axiom Form": {
    "prefix": "ax-form",
    "body": [
      "<form class=\"form\" novalidate>",
      "\t<fieldset>",
      "\t\t<legend>$1</legend>",
      "\t\t<div class=\"field\">",
      "\t\t\t<label for=\"${2:field-id}\">$3</label>",
      "\t\t\t<input type=\"${4|text,email,password,tel,url|}\" id=\"${2:field-id}\" name=\"${2:field-id}\" required>",
      "\t\t\t<small class=\"help\">$5</small>",
      "\t\t</div>",
      "\t</fieldset>",
      "\t<footer>",
      "\t\t<button type=\"submit\" class=\"primary\">Submit</button>",
      "\t</footer>",
      "</form>"
    ],
    "description": "Creates an Axiom01 form with validation structure"
  },
  "Axiom Navigation": {
    "prefix": "ax-nav",
    "body": [
      "<nav class=\"navbar\" role=\"navigation\" aria-label=\"${1:Main navigation}\">",
      "\t<div class=\"nav-brand\">",
      "\t\t<a href=\"/\">$2</a>",
      "\t</div>",
      "\t<ul class=\"nav-menu\">",
      "\t\t<li><a href=\"#\">$3</a></li>",
      "\t\t<li><a href=\"#\">$4</a></li>",
      "\t\t<li><a href=\"#\">$5</a></li>",
      "\t</ul>",
      "</nav>"
    ],
    "description": "Creates an accessible Axiom01 navigation bar"
  },
  "Axiom Alert": {
    "prefix": "ax-alert",
    "body": [
      "<div class=\"alert ${1|info,success,warning,error|}\" role=\"${2|alert,status|}\" aria-live=\"${3|polite,assertive|}\">",
      "\t<strong>$4</strong> $5",
      "\t<button class=\"close\" aria-label=\"Dismiss alert\">&times;</button>",
      "</div>"
    ],
    "description": "Creates an accessible Axiom01 alert component"
  },
  "Axiom Tabs": {
    "prefix": "ax-tabs",
    "body": [
      "<div class=\"tabs\">",
      "\t<div class=\"tablist\" role=\"tablist\" aria-label=\"$1\">",
      "\t\t<button class=\"tab\" role=\"tab\" aria-selected=\"true\" aria-controls=\"panel-1\" id=\"tab-1\">$2</button>",
      "\t\t<button class=\"tab\" role=\"tab\" aria-selected=\"false\" aria-controls=\"panel-2\" id=\"tab-2\">$3</button>",
      "\t</div>",
      "\t<div class=\"tabpanel\" role=\"tabpanel\" aria-labelledby=\"tab-1\" id=\"panel-1\">",
      "\t\t<p>$4</p>",
      "\t</div>",
      "\t<div class=\"tabpanel\" role=\"tabpanel\" aria-labelledby=\"tab-2\" id=\"panel-2\" hidden>",
      "\t\t<p>$5</p>",
      "\t</div>",
      "</div>"
    ],
    "description": "Creates accessible Axiom01 tabs with ARIA support"
  },
  "Axiom Table": {
    "prefix": "ax-table",
    "body": [
      "<table class=\"table\">",
      "\t<caption>$1</caption>",
      "\t<thead>",
      "\t\t<tr>",
      "\t\t\t<th scope=\"col\">$2</th>",
      "\t\t\t<th scope=\"col\">$3</th>",
      "\t\t\t<th scope=\"col\">$4</th>",
      "\t\t</tr>",
      "\t</thead>",
      "\t<tbody>",
      "\t\t<tr>",
      "\t\t\t<td>$5</td>",
      "\t\t\t<td>$6</td>",
      "\t\t\t<td>$7</td>",
      "\t\t</tr>",
      "\t</tbody>",
      "</table>"
    ],
    "description": "Creates an accessible Axiom01 table with proper semantics"
  }
}

