{
  "Axiom CSS Variable": {
    "prefix": "ax-var",
    "body": [
      "var(--a-${1|color,space,size,font,radius,shadow,transition|}-${2:name})"
    ],
    "description": "Insert Axiom01 CSS custom property"
  },
  "Axiom Color Variable": {
    "prefix": "ax-color",
    "body": [
      "var(--a-color-${1|primary,secondary,accent,neutral,success,warning,error,info|}-${2|50,100,200,300,400,500,600,700,800,900|})"
    ],
    "description": "Insert Axiom01 color variable"
  },
  "Axiom Space Variable": {
    "prefix": "ax-space",
    "body": [
      "var(--a-space-${1|xs,sm,md,lg,xl,2xl,3xl,4xl|})"
    ],
    "description": "Insert Axiom01 spacing variable"
  },
  "Axiom Component Base": {
    "prefix": "ax-component",
    "body": [
      ".${1:component-name} {",
      "\t/* Layout */",
      "\tdisplay: ${2|block,flex,grid,inline-block|};",
      "\t${3:gap: var(--a-space-md);}",
      "\t",
      "\t/* Colors */",
      "\tbackground: var(--a-color-${4:surface});",
      "\tcolor: var(--a-color-${5:text});",
      "\tborder: 1px solid var(--a-color-${6:border});",
      "\t",
      "\t/* Typography */",
      "\tfont-family: var(--a-font-${7:body});",
      "\tfont-size: var(--a-size-${8:md});",
      "\tline-height: var(--a-line-height-${9:normal});",
      "\t",
      "\t/* Spacing */",
      "\tpadding: var(--a-space-${10:md});",
      "\tmargin: ${11:0};",
      "\t",
      "\t/* Border & Effects */",
      "\tborder-radius: var(--a-radius-${12:md});",
      "\tbox-shadow: var(--a-shadow-${13:sm});",
      "\ttransition: var(--a-transition-${14:default});",
      "}"
    ],
    "description": "Creates a base Axiom01 component class with design tokens"
  },
  "Axiom Focus States": {
    "prefix": "ax-focus",
    "body": [
      "&:focus-visible {",
      "\toutline: 2px solid var(--a-color-focus);",
      "\toutline-offset: 2px;",
      "}",
      "",
      "&:focus:not(:focus-visible) {",
      "\toutline: none;",
      "}"
    ],
    "description": "Adds consistent Axiom01 focus states"
  },
  "Axiom Interactive States": {
    "prefix": "ax-states",
    "body": [
      "&:hover {",
      "\tbackground: var(--a-color-${1:primary}-${2:600});",
      "\ttransform: translateY(-1px);",
      "}",
      "",
      "&:active {",
      "\ttransform: translateY(0);",
      "}",
      "",
      "&:disabled {",
      "\topacity: 0.6;",
      "\tpointer-events: none;",
      "}"
    ],
    "description": "Adds interactive states following Axiom01 patterns"
  },
  "Axiom Responsive Breakpoint": {
    "prefix": "ax-breakpoint",
    "body": [
      "@media (min-width: ${1|480px,768px,1024px,1200px|}) {",
      "\t$2",
      "}"
    ],
    "description": "Creates responsive breakpoint using Axiom01 standards"
  },
  "Axiom Dark Mode": {
    "prefix": "ax-dark",
    "body": [
      "@media (prefers-color-scheme: dark) {",
      "\t$1",
      "}",
      "",
      "[data-theme=\"dark\"] & {",
      "\t$2",
      "}"
    ],
    "description": "Adds dark mode styles using Axiom01 patterns"
  }
}

