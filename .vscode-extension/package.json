{
  "name": "axiom01-snippets",
  "displayName": "Axiom01 UI Framework Snippets",
  "description": "Code snippets and autocomplete for the Axiom01 UI Framework",
  "version": "1.0.0",
  "publisher": "axiom01",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Snippets",
    "Other"
  ],
  "keywords": [
    "axiom01",
    "ui",
    "framework",
    "css",
    "html",
    "snippets"
  ],
  "contributes": {
    "snippets": [
      {
        "language": "html",
        "path": "./snippets/html.json"
      },
      {
        "language": "css",
        "path": "./snippets/css.json"
      },
      {
        "language": "javascript",
        "path": "./snippets/javascript.json"
      }
    ],
    "languages": [
      {
        "id": "axiom-config",
        "aliases": ["Axiom Config"],
        "extensions": [".axiom"]
      }
    ]
  },
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/axiom01/vscode-extension"
  },
  "license": "MIT"
}

